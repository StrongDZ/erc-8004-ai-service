# MongoDB (notebooks + optional data extraction)
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE_ANALYZED_AGENTS=analyzed_agents
MONGO_COLLECTION_FEEDBACK_HISTORY=feedback_history
MONGO_COLLECTION_AGENTS=agents

# Ollama (native host — not Docker)
LLM_BASE_URL=http://localhost:11434

# Defaults used by the FastAPI service (app/deps.py)
AI_SERVICE_DEFAULT_MODEL=qwen2.5:7b-instruct
AI_SERVICE_DEFAULT_EMBED_MODEL=BAAI/bge-base-en-v1.5

# Runtime classify cache (best-effort; MongoDB collection classify_cache; ENABLED=0 to disable)
AI_SERVICE_CACHE_TTL_SECONDS=5184000
AI_SERVICE_CACHE_ENABLED=1
